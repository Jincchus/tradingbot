DATABASE_URL=postgresql://postgres:password@localhost:5432/tradingbot
# 웹 프론트엔드 origin (CORS 허용). 쉼표로 다중 지정.
CORS_ORIGINS=http://localhost:3000

# 시세(StockDataStream)용 Alpaca 키 — 거래용 키와 분리된 별도 로그인.
# MarketDataHub가 이 키로 시세 웹소켓 1개만 연결해 모든 전략에 분배(팬아웃).
# 거래/체결용 키는 전략별로 DB(strategies.alpaca_key/secret)에 저장됨.
ALPACA_DATA_KEY=
ALPACA_DATA_SECRET=
